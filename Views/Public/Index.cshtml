@model MGold.Controllers.PublicProductsPageViewModel
@{
    ViewData["Title"] = "Dashboard";
    ViewData["PageDescription"] = "Ana ozetleri gor, hizli alanlardan urunler ve hesap modullerine gec.";
}

@section Styles {
    <style>
        .hero-panel {
            display: grid;
            grid-template-columns: 1.3fr .95fr;
            gap: 18px;
            padding: 18px;
            background:
                radial-gradient(circle at top right, rgba(255, 216, 127, 0.34), transparent 28%),
                linear-gradient(145deg, rgba(72, 48, 18, 0.98) 0%, rgba(120, 82, 28, 0.94) 100%);
            color: #fff4dc;
        }
        .hero-content {
            padding: 12px;
        }
        .hero-kicker {
            display: inline-flex;
            padding: 7px 11px;
            border-radius: 999px;
            background: rgba(255,255,255,0.12);
            font-size: 12px;
            font-weight: 700;
            letter-spacing: .06em;
            text-transform: uppercase;
        }
        .hero-content h2 {
            margin: 16px 0 10px;
            font-family: "Space Grotesk", sans-serif;
            font-size: clamp(28px, 4vw, 42px);
            line-height: 1.02;
        }
        .hero-content p {
            margin: 0;
            max-width: 650px;
            color: rgba(255, 244, 220, 0.82);
            line-height: 1.7;
        }
        .hero-actions {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            margin-top: 20px;
        }
        .hero-actions .btn-secondary {
            color: #fff5e5;
            background: rgba(255,255,255,0.08);
            border-color: rgba(255,255,255,0.14);
        }
        .signal-grid {
            display: grid;
            gap: 12px;
        }
        .signal-card {
            padding: 16px;
            border-radius: 22px;
            background: rgba(255,255,255,0.1);
            border: 1px solid rgba(255,255,255,0.12);
        }
        .signal-card strong {
            display: block;
            font-size: 13px;
            color: rgba(255, 243, 215, 0.72);
        }
        .signal-card span {
            display: block;
            margin-top: 8px;
            font-size: 26px;
            font-weight: 800;
            color: #fff6e3;
        }
        .metrics-grid {
            display: grid;
            grid-template-columns: repeat(4, minmax(0, 1fr));
            gap: 16px;
            margin-top: 18px;
        }
        .metric-card {
            padding: 18px;
        }
        .metric-card strong {
            display: block;
            color: var(--muted);
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: .08em;
        }
        .metric-card span {
            display: block;
            margin-top: 10px;
            font-family: "Space Grotesk", sans-serif;
            font-size: 32px;
            color: var(--brand-strong);
        }
        .metric-card p {
            margin: 8px 0 0;
            color: var(--muted);
            font-size: 14px;
        }
        .content-grid {
            display: grid;
            grid-template-columns: 1.05fr .95fr;
            gap: 18px;
            margin-top: 18px;
            align-items: start;
        }
        .panel-actions {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            align-items: center;
        }
        .message {
            padding: 12px 14px;
            border-radius: 16px;
            font-size: 14px;
        }
        .message-success {
            color: #20563f;
            background: rgba(208, 244, 228, 0.9);
            border: 1px solid rgba(45, 122, 87, 0.18);
        }
        .message-error {
            color: #8f3030;
            background: rgba(255, 236, 236, 0.92);
            border: 1px solid rgba(183, 71, 71, 0.18);
        }
        .quick-grid,
        .quick-info {
            display: grid;
            gap: 14px;
        }
        .quick-note {
            padding: 16px;
            border-radius: 18px;
            background: rgba(255,255,255,0.72);
            border: 1px solid rgba(98, 67, 25, 0.08);
        }
        .spotlight-card {
            padding: 22px;
        }
        .spotlight-card h2 {
            margin: 0;
            font-family: "Space Grotesk", sans-serif;
            font-size: 28px;
        }
        .spotlight-card p {
            margin: 10px 0 18px;
            color: var(--muted);
            line-height: 1.65;
        }
        .route-list {
            display: grid;
            gap: 12px;
        }
        .route-item {
            padding: 16px;
            border-radius: 18px;
            background: rgba(255,255,255,0.72);
            border: 1px solid rgba(98, 67, 25, 0.08);
        }
        @@media (max-width: 1200px) {
            .metrics-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
            .content-grid { grid-template-columns: 1fr; }
            .hero-panel { grid-template-columns: 1fr; }
        }
        @@media (max-width: 760px) {
            .metrics-grid { grid-template-columns: 1fr; }
        }
    </style>
}

<div class="stack">
    <section class="surface hero-panel">
        <div class="hero-content">
            <span class="hero-kicker">Musteri deneyimi</span>
            <h2>Kullanici ve admin akislari ayrildi; burada sadece sade musteri deneyimi var.</h2>
            <p>Urunleri inceleyebilir, musteri hesabi olusturabilir ve kendi panelinizden siparislerinizi takip edebilirsiniz. Yonetim islemleri ise artik tamamen ayri admin panelinde yer alir.</p>
            <div class="hero-actions">
                <a class="btn btn-primary" asp-controller="Public" asp-action="Products">Urunler Sayfasina Git</a>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a class="btn btn-secondary" asp-controller="Customer" asp-action="Index">Musteri Panelimi Ac</a>
                }
            </div>
        </div>
        <div class="signal-grid">
            <div class="signal-card">
                <strong>Toplam urun</strong>
                <span>@Model.Dashboard.TotalProducts</span>
            </div>
            <div class="signal-card">
                <strong>Toplam stok</strong>
                <span>@Model.Dashboard.TotalStock</span>
            </div>
            <div class="signal-card">
                <strong>Acik siparisler</strong>
                <span>@Model.Dashboard.OpenOrders</span>
            </div>
        </div>
    </section>

    <section class="metrics-grid">
        <article class="surface metric-card">
            <strong>Toplam Urun</strong>
            <span>@Model.Dashboard.TotalProducts</span>
            <p>Veritabanindaki toplam urun kaydi.</p>
        </article>
        <article class="surface metric-card">
            <strong>Dusuk Stok</strong>
            <span>@Model.Dashboard.LowStockCount</span>
            <p>Hizli takip gerektiren urun adedi.</p>
        </article>
        <article class="surface metric-card">
            <strong>Toplam Ciro</strong>
            <span>@Model.Dashboard.TotalRevenue.ToString("N0")</span>
            <p>Satistan gelen toplam hacim.</p>
        </article>
        <article class="surface metric-card">
            <strong>Net Kar/Zarar</strong>
            <span>@Model.Dashboard.NetProfit.ToString("N0")</span>
            <p>Islem kayitlarindan hesaplanan ozet.</p>
        </article>
    </section>

    <section class="content-grid">
        <article class="surface spotlight-card">
            <h2>Urunler</h2>
            <p>Urun listesi artik musteri akisina odaklanir. Siparis verme, filtreleme ve detay inceleme ayni sade deneyim icinde sunulur.</p>
            <div class="panel-actions">
                <a class="btn btn-primary" asp-controller="Public" asp-action="Products">Urunler Sayfasini Ac</a>
            </div>
            <div class="route-list" style="margin-top:18px;">
                <div class="route-item">
                    <strong>Daha net gorunum</strong>
                    <div class="text-muted">Liste artik dashboard icinde dip dibe degil; ayrilmis ekranda daha rahat okunuyor.</div>
                </div>
                <div class="route-item">
                    <strong>Hizli siparis</strong>
                    <div class="text-muted">Siparis butonlari urun satiri icinde korunuyor ama ekran sadece listeye odaklaniyor.</div>
                </div>
            </div>
        </article>

        <article class="surface surface-inner stack">
            <div>
                <h2 class="section-title">Siparis ve Hesap</h2>
                <p class="section-copy">Siparis vermek icin giris yapman gerekir. Yonetim islemleri ayri admin modullerine tasindi.</p>
            </div>
            @if (TempData["Success"] is string ok && !string.IsNullOrWhiteSpace(ok))
            {
                <div class="message message-success">@ok</div>
            }
            @if (TempData["Error"] is string error && !string.IsNullOrWhiteSpace(error))
            {
                <div class="message message-error">@error</div>
            }
            @if (ViewData["LoadError"] is string loadError && !string.IsNullOrWhiteSpace(loadError))
            {
                <div class="message message-error">@loadError</div>
            }

                <div class="quick-info">
                    <div class="quick-note">
                        <strong>Guvenli siparis</strong>
                        <div class="text-muted">Urun siparisi icin giris yapmaniz gerekmektedir. Sabit butondan modal giris ekranini acabilirsiniz.</div>
                    </div>
                    <div class="quick-note">
                        <strong>Profil ve gecmis</strong>
                        <div class="text-muted">Giris yapan kullanicilar profil ekranindan gecmis siparislerini goruntuleyebilir.</div>
                    </div>
                    @if (User.IsInRole("Manager"))
                    {
                        <div class="quick-note">
                            <strong>Firma urun yonetimi</strong>
                            <div class="text-muted">Urun ekleme, duzenleme ve silme artik ayri admin urun modulu uzerinden yapiliyor.</div>
                            <div class="panel-actions" style="margin-top:12px;">
                                <a class="btn btn-primary" asp-controller="Admin" asp-action="Products">Urun Yonetimine Git</a>
                            </div>
                        </div>
                    }
                </div>
        </article>
    </section>
</div>
