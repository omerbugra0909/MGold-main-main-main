@using MGold.Domain.Constants
@{
    var title = ViewData["Title"]?.ToString() ?? "MGold";
    var description = ViewData["PageDescription"]?.ToString() ?? "Kuyumculuk urunlerini incele, hesap olustur ve siparislerini takip et.";
    var path = Context.Request.Path.Value ?? "/";
    var isAuthenticated = User.Identity?.IsAuthenticated == true;
    var isSystemAdmin = User.IsInRole(RoleConstants.SystemAdmin);
    var isManager = User.IsInRole(RoleConstants.Manager);
    var isEmployee = User.IsInRole(RoleConstants.Employee);
}
<!doctype html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@title - MGold</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Cinzel:wght@600;700&display=swap" rel="stylesheet">
    @await Html.PartialAsync("_ThemeHead")
    <style>
        :root {
            color-scheme: dark;
            --bg-0: #08090d;
            --bg-1: #10131a;
            --bg-2: #171b22;
            --panel: linear-gradient(180deg, rgba(21, 24, 30, 0.92), rgba(11, 13, 17, 0.95));
            --panel-soft: rgba(255, 255, 255, 0.04);
            --line: rgba(199, 155, 83, 0.14);
            --ink: #f3ecdf;
            --muted: #9b9184;
            --gold-0: #e3c991;
            --gold-1: #c79b53;
            --gold-2: #8f632b;
            --silver: #aeb6c1;
            --copper: #916348;
            --diamond: #8fc5da;
            --shadow: 0 30px 90px rgba(0, 0, 0, 0.42);
            --radius-xl: 30px;
            --radius-lg: 22px;
            --transition: 280ms cubic-bezier(.2,.8,.2,1);
        }
        * { box-sizing: border-box; }
        html { scroll-behavior: smooth; }
        body {
            margin: 0;
            min-height: 100vh;
            font-family: "Manrope", sans-serif;
            color: var(--ink);
            background:
                radial-gradient(circle at 12% 8%, rgba(199, 155, 83, 0.12), transparent 24%),
                radial-gradient(circle at 88% 10%, rgba(143, 197, 218, 0.05), transparent 18%),
                radial-gradient(circle at 50% 100%, rgba(145, 99, 72, 0.07), transparent 22%),
                linear-gradient(145deg, var(--bg-0) 0%, var(--bg-1) 46%, var(--bg-2) 100%);
            overflow-x: hidden;
        }
        body::before,
        body::after {
            content: "";
            position: fixed;
            inset: 0;
            pointer-events: none;
            z-index: -2;
        }
        body::before {
            background:
                linear-gradient(120deg, rgba(255,255,255,0.02), transparent 30%, rgba(255,255,255,0.015) 58%, transparent 80%);
            animation: sheen-pan 18s linear infinite;
        }
        body::after {
            inset: 18px;
            border: 1px solid rgba(255, 214, 116, 0.05);
            border-radius: 30px;
            z-index: -1;
        }
        a { color: inherit; text-decoration: none; }
        .shell {
            width: min(1280px, calc(100% - 40px));
            margin: 0 auto;
            position: relative;
        }
        .topbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 18px;
            padding: 24px 0;
            position: sticky;
            top: 0;
            z-index: 30;
            backdrop-filter: blur(18px);
        }
        .topbar::before {
            content: "";
            position: absolute;
            inset: 10px -18px;
            border-radius: 26px;
            background: linear-gradient(180deg, rgba(10, 12, 16, 0.9), rgba(10, 12, 16, 0.55));
            border: 1px solid rgba(255, 214, 116, 0.08);
            z-index: -1;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.35);
        }
        .brand {
            display: flex;
            align-items: center;
            gap: 16px;
            min-width: 0;
        }
        .brand-copy {
            display: grid;
            gap: 4px;
        }
        .brand-copy strong {
            font-family: "Cinzel", serif;
            letter-spacing: .06em;
            font-size: 26px;
            color: var(--gold-0);
            text-shadow: 0 0 18px rgba(244, 200, 106, 0.12);
        }
        .brand-copy span {
            color: var(--muted);
            font-size: 13px;
        }
        .nav {
            display: flex;
            align-items: center;
            gap: 10px;
            flex-wrap: wrap;
            justify-content: flex-end;
        }
        .btn {
            position: relative;
            overflow: hidden;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-height: 46px;
            padding: 11px 18px;
            border-radius: 999px;
            border: 1px solid transparent;
            font: inherit;
            font-weight: 700;
            cursor: pointer;
            transition: transform var(--transition), border-color var(--transition), box-shadow var(--transition), background var(--transition), color var(--transition);
            will-change: transform;
        }
        .btn::before {
            content: "";
            position: absolute;
            inset: 0;
            background: linear-gradient(120deg, transparent 25%, rgba(255,255,255,0.18) 50%, transparent 75%);
            transform: translateX(-120%);
            transition: transform 700ms ease;
        }
        .btn:hover::before { transform: translateX(120%); }
        .btn:hover { transform: translateY(-2px) scale(1.01); }
        .btn-primary {
            background: linear-gradient(135deg, rgba(227, 201, 145, 0.16), rgba(143, 99, 43, 0.34));
            border-color: rgba(199, 155, 83, 0.24);
            color: var(--gold-0);
            box-shadow: 0 16px 40px rgba(93, 62, 26, 0.22), inset 0 1px 0 rgba(255,255,255,0.1);
        }
        .btn-secondary {
            background: rgba(255,255,255,0.03);
            border-color: rgba(255,255,255,0.08);
            color: #efe6d1;
        }
        .btn-secondary:hover {
            border-color: rgba(255, 214, 116, 0.18);
            box-shadow: 0 18px 36px rgba(0, 0, 0, 0.24);
        }
        .page-header {
            padding: 8px 0 20px;
            animation: fade-up .8s cubic-bezier(.2,.8,.2,1) both;
        }
        .page-header h1 {
            margin: 0;
            font-family: "Cinzel", serif;
            font-size: clamp(30px, 4vw, 44px);
            letter-spacing: .04em;
        }
        .page-header p {
            margin: 10px 0 0;
            max-width: 800px;
            color: var(--muted);
        }
        .page-body {
            padding-bottom: 42px;
            animation: page-enter .95s cubic-bezier(.2,.8,.2,1) both;
        }
        .surface,
        .hero {
            position: relative;
            overflow: hidden;
            border-radius: var(--radius-xl);
            border: 1px solid rgba(255, 214, 116, 0.08);
            box-shadow: var(--shadow);
            backdrop-filter: blur(20px);
            transform-origin: center;
            transition: transform var(--transition), border-color var(--transition), box-shadow var(--transition), background var(--transition);
        }
        .surface {
            background: var(--panel);
        }
        .surface::before,
        .hero::before {
            content: "";
            position: absolute;
            inset: 1px;
            border-radius: inherit;
            background:
                linear-gradient(180deg, rgba(255,255,255,0.06), transparent 30%),
                radial-gradient(circle at top right, rgba(255, 214, 116, 0.08), transparent 24%);
            pointer-events: none;
        }
        .surface:hover,
        .hero:hover {
            transform: translateY(-5px);
            border-color: rgba(255, 214, 116, 0.18);
            box-shadow: 0 36px 120px rgba(0, 0, 0, 0.5);
        }
        .hero {
            padding: 34px;
            background:
                radial-gradient(circle at top right, rgba(255, 228, 162, 0.18), transparent 22%),
                linear-gradient(145deg, rgba(24, 19, 14, 0.95) 0%, rgba(13, 14, 18, 0.96) 100%);
            color: #fff7e6;
        }
        .hero h1 {
            margin: 0;
            font-family: "Cinzel", serif;
            font-size: clamp(38px, 5vw, 62px);
            line-height: 1;
            letter-spacing: .05em;
        }
        .hero p {
            max-width: 820px;
            margin: 16px 0 0;
            color: rgba(247, 240, 222, 0.74);
            line-height: 1.72;
        }
        .badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 7px 12px;
            border-radius: 999px;
            background: rgba(255, 214, 116, 0.08);
            border: 1px solid rgba(255, 214, 116, 0.12);
            color: var(--gold-1);
            font-size: 11px;
            font-weight: 800;
            letter-spacing: .12em;
            text-transform: uppercase;
        }
        .text-muted { color: var(--muted); }
        .empty-state {
            padding: 18px;
            border-radius: 20px;
            border: 1px dashed rgba(255, 214, 116, 0.12);
            background: rgba(255,255,255,0.03);
            color: var(--muted);
        }
        input, select, textarea {
            width: 100%;
            border: 1px solid rgba(255, 214, 116, 0.12);
            border-radius: 18px;
            padding: 12px 14px;
            background: rgba(255,255,255,0.04);
            color: var(--ink);
            font: inherit;
            transition: border-color var(--transition), box-shadow var(--transition), transform var(--transition), background var(--transition);
        }
        input:focus, select:focus, textarea:focus {
            outline: none;
            border-color: rgba(255, 214, 116, 0.32);
            background: rgba(255,255,255,0.06);
            box-shadow: 0 0 0 4px rgba(244, 200, 106, 0.08);
            transform: translateY(-1px);
        }
        .validation-summary-errors,
        .field-validation-error {
            color: #ff9494;
            font-size: 13px;
        }
        .validation-summary-errors {
            padding: 12px 14px;
            border-radius: 16px;
            background: rgba(133, 31, 31, 0.24);
            border: 1px solid rgba(255, 117, 117, 0.18);
        }
        .brand-scene {
            --coin-tilt-x: -16deg;
            --coin-tilt-y: 22deg;
            --coin-drag-rotate: 0deg;
            position: relative;
            perspective: 1800px;
            display: grid;
            place-items: center;
            pointer-events: none;
            user-select: none;
        }
        .brand-scene-compact { width: 82px; height: 82px; flex: 0 0 auto; }
        .brand-scene-hero {
            width: min(520px, 100%);
            min-height: 520px;
            pointer-events: auto;
            cursor: grab;
            touch-action: none;
            -webkit-user-select: none;
            -webkit-touch-callout: none;
        }
        .brand-scene-hero:active { cursor: grabbing; }
        .brand-scene-copy {
            position: absolute;
            bottom: 8px;
            left: 50%;
            transform: translateX(-50%);
            display: grid;
            gap: 5px;
            text-align: center;
            z-index: 4;
        }
        .brand-scene-copy strong {
            font-family: "Cinzel", serif;
            font-size: clamp(28px, 4vw, 46px);
            color: var(--gold-0);
            letter-spacing: .14em;
            text-shadow: 0 0 24px rgba(199, 155, 83, 0.14);
        }
        .brand-scene-copy span:last-of-type {
            color: rgba(247, 240, 222, 0.64);
            font-size: 12px;
            letter-spacing: .18em;
            text-transform: uppercase;
        }
        .brand-scene-copy em {
            font-style: normal;
            color: rgba(255, 214, 116, 0.76);
            font-size: 11px;
            letter-spacing: .24em;
            text-transform: uppercase;
        }
        .brand-scene-kicker {
            color: rgba(255, 214, 116, 0.82);
            font-size: 11px;
            letter-spacing: .28em;
            text-transform: uppercase;
        }
        .brand-scene-core {
            position: relative;
            width: 100%;
            aspect-ratio: 1;
            display: grid;
            place-items: center;
            transform-style: preserve-3d;
            filter: drop-shadow(0 32px 56px rgba(0,0,0,0.52));
        }
        .brand-coin-aura {
            position: absolute;
            inset: 10%;
            border-radius: 50%;
            background:
                radial-gradient(circle, rgba(255, 214, 116, 0.18), rgba(255, 214, 116, 0.05) 36%, transparent 68%),
                radial-gradient(circle at 32% 28%, rgba(255,255,255,0.18), transparent 18%);
            filter: blur(22px);
            animation: aura-breathe 6s ease-in-out infinite;
        }
        .brand-coin-stage {
            position: relative;
            width: 78%;
            aspect-ratio: 1;
            display: grid;
            place-items: center;
            transform-style: preserve-3d;
            animation: stage-sway 9s ease-in-out infinite;
        }
        .brand-coin-motion {
            position: relative;
            width: 86%;
            aspect-ratio: 1;
            display: grid;
            place-items: center;
            transform-style: preserve-3d;
            animation: coin-float 7.6s ease-in-out infinite;
        }
        .brand-coin-shadow {
            position: absolute;
            inset: 24% 12% 12%;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(0,0,0,0.58), rgba(0,0,0,0.08) 62%, transparent 78%);
            filter: blur(26px);
            transform: translateZ(-50px) rotateX(84deg) scale(1.18);
            animation: shadow-breathe 6s ease-in-out infinite;
        }
        .brand-coin {
            position: relative;
            width: 100%;
            aspect-ratio: 1;
            transform-style: preserve-3d;
            transform:
                rotateX(var(--coin-tilt-x))
                rotateY(calc(var(--coin-tilt-y) + var(--coin-drag-rotate)))
                translateZ(0);
            transition: transform 180ms ease-out;
            will-change: transform;
        }
        .brand-coin-side {
            position: absolute;
            inset: 7%;
            border-radius: 50%;
            background:
                repeating-conic-gradient(
                    from 0deg,
                    rgba(230, 205, 151, 0.82) 0deg 8deg,
                    rgba(126, 86, 36, 0.86) 8deg 16deg
                );
            transform: translateZ(-24px);
            box-shadow:
                inset 0 0 0 8px rgba(91, 59, 24, 0.4),
                0 10px 32px rgba(0,0,0,0.22);
            filter: saturate(.94);
        }
        .brand-coin-face {
            position: absolute;
            inset: 0;
            border-radius: 50%;
            display: grid;
            place-items: center;
            backface-visibility: hidden;
            overflow: hidden;
        }
        .brand-coin-front,
        .brand-coin-back {
            background:
                radial-gradient(circle at 26% 18%, rgba(245, 236, 212, 0.95), rgba(225, 198, 140, 0.9) 16%, rgba(186, 139, 72, 0.88) 50%, rgba(116, 78, 34, 0.94) 74%, rgba(45, 31, 13, 0.98) 100%);
            box-shadow:
                inset 0 14px 24px rgba(255,255,255,0.16),
                inset 0 -18px 28px rgba(74, 48, 21, 0.42),
                0 0 44px rgba(199, 155, 83, 0.12);
        }
        .brand-coin-front { transform: translateZ(24px); }
        .brand-coin-back { transform: rotateY(180deg) translateZ(24px); }
        .brand-coin-face-sheen {
            position: absolute;
            inset: -10%;
            background:
                linear-gradient(120deg, transparent 24%, rgba(255,255,255,0.28) 40%, transparent 56%),
                linear-gradient(200deg, transparent 16%, rgba(227, 201, 145, 0.08) 36%, transparent 62%);
            mix-blend-mode: screen;
            animation: coin-sheen 5.2s linear infinite;
        }
        .brand-coin-rim {
            position: absolute;
            border-radius: 50%;
            border-style: solid;
        }
        .brand-coin-rim-outer {
            inset: 4.5%;
            border-width: 2px;
            border-color: rgba(243, 228, 193, 0.46);
            box-shadow:
                inset 0 0 0 10px rgba(106, 71, 31, 0.16),
                0 0 16px rgba(199, 155, 83, 0.08);
        }
        .brand-coin-rim-inner {
            inset: 13%;
            border-width: 1px;
            border-color: rgba(243, 230, 204, 0.24);
            box-shadow: inset 0 0 0 5px rgba(227, 201, 145, 0.04);
        }
        .brand-coin-center {
            position: relative;
            width: 58%;
            aspect-ratio: 1;
            border-radius: 50%;
            display: grid;
            place-items: center;
            align-content: center;
            gap: 4px;
            background:
                radial-gradient(circle at 30% 24%, rgba(232, 214, 177, 0.18), rgba(255,255,255,0.03) 28%, transparent 62%),
                radial-gradient(circle, rgba(78, 53, 26, 0.18), transparent 70%);
            box-shadow:
                inset 0 0 0 1px rgba(255,255,255,0.1),
                inset 0 10px 16px rgba(255,255,255,0.04),
                inset 0 -12px 16px rgba(54, 35, 15, 0.14);
            transform: translateZ(10px);
        }
        .brand-coin-engrave {
            position: relative;
            font-family: "Cinzel", serif;
            font-size: clamp(22px, 4.3vw, 60px);
            letter-spacing: .11em;
            color: rgba(67, 43, 18, 0.9);
            text-shadow:
                0 1px 0 rgba(255,255,255,0.22),
                0 -1px 0 rgba(78, 51, 22, 0.28),
                0 8px 16px rgba(76, 50, 22, 0.12);
            transform: translateZ(12px);
        }
        .brand-coin-etch {
            position: absolute;
            inset: 20%;
            border-radius: 50%;
            border: 1px solid rgba(227, 201, 145, 0.1);
            transform: translateZ(6px);
        }
        .brand-coin-etch-b { inset: 24%; border-style: dashed; opacity: .46; }
        .brand-coin-glyph {
            position: absolute;
            width: 54%;
            height: 2px;
            background: linear-gradient(90deg, transparent, rgba(233, 220, 190, 0.56), transparent);
            opacity: .58;
        }
        .brand-coin-glyph-top { top: 24%; }
        .brand-coin-glyph-bottom { bottom: 24%; }
        .brand-coin-insignia {
            width: 40%;
            height: 40%;
            border-radius: 50%;
            background:
                radial-gradient(circle at 32% 32%, rgba(255,255,255,0.2), transparent 18%),
                radial-gradient(circle, rgba(104, 57, 12, 0.78), rgba(66, 35, 7, 0.18));
            box-shadow:
                inset 0 0 0 1px rgba(255,255,255,0.24),
                inset 0 12px 16px rgba(255,255,255,0.1);
            transform: translateZ(8px);
        }
        .brand-coin-back-grid {
            position: absolute;
            inset: 26%;
            border-radius: 50%;
            background:
                repeating-linear-gradient(0deg, transparent 0 12%, rgba(255,255,255,0.04) 12% 14%, transparent 14% 26%),
                repeating-linear-gradient(90deg, transparent 0 12%, rgba(255,255,255,0.04) 12% 14%, transparent 14% 26%);
            opacity: .55;
        }
        .brand-glow-ring {
            position: absolute;
            aspect-ratio: 1;
            border-radius: 50%;
            animation: glow-pulse 4.6s ease-in-out infinite;
        }
        .brand-glow-ring-outer {
            width: 88%;
            border: 1px solid rgba(199, 155, 83, 0.14);
            box-shadow: 0 0 36px rgba(199, 155, 83, 0.12), inset 0 0 26px rgba(199, 155, 83, 0.03);
        }
        .brand-glow-ring-inner {
            width: 64%;
            border: 1px solid rgba(233, 220, 190, 0.09);
            animation-delay: -.8s;
        }
        .brand-orbit {
            position: absolute;
            border-radius: 50%;
            border: 1px dashed rgba(255,255,255,0.08);
            animation: orbit-spin 12s linear infinite;
            pointer-events: none;
        }
        .brand-orbit::before,
        .brand-orbit::after {
            content: "";
            position: absolute;
            border-radius: 50%;
            filter: drop-shadow(0 0 14px currentColor);
        }
        .brand-orbit-silver { inset: 4%; color: rgba(174, 182, 193, 0.78); }
        .brand-orbit-silver::before { width: 12px; height: 12px; top: -5px; left: 40%; background: currentColor; }
        .brand-orbit-silver::after { width: 8px; height: 8px; bottom: 14%; right: 10%; background: currentColor; }
        .brand-orbit-copper {
            inset: 14%;
            animation-duration: 18s;
            animation-direction: reverse;
            color: rgba(145, 99, 72, 0.7);
        }
        .brand-orbit-copper::before { width: 14px; height: 14px; top: 19%; right: -4px; background: currentColor; }
        .brand-orbit-copper::after { width: 8px; height: 8px; bottom: -2px; left: 28%; background: currentColor; }
        .brand-orbit-gem {
            inset: -3%;
            animation-duration: 26s;
            color: rgba(143, 197, 218, 0.76);
        }
        .brand-orbit-gem::before {
            width: 16px;
            height: 16px;
            top: 32%;
            left: -2px;
            background: radial-gradient(circle at 30% 30%, #ffffff, currentColor 45%, rgba(143, 197, 218, 0.15) 100%);
            clip-path: polygon(50% 0%, 100% 35%, 78% 100%, 22% 100%, 0% 35%);
        }
        .brand-orbit-gem::after { width: 9px; height: 9px; top: 7%; right: 18%; background: currentColor; }
        .brand-particle {
            position: absolute;
            border-radius: 50%;
            opacity: .92;
            animation: sparkle 3.4s ease-in-out infinite alternate;
            pointer-events: none;
        }
        .brand-particle-diamond {
            width: 18px;
            height: 18px;
            top: 18%;
            right: 16%;
            background: radial-gradient(circle at 30% 30%, #ffffff, rgba(143, 197, 218, 0.82) 45%, rgba(143, 197, 218, 0.14) 100%);
            clip-path: polygon(50% 0%, 100% 36%, 78% 100%, 22% 100%, 0% 36%);
        }
        .brand-particle-silver { width: 12px; height: 12px; left: 14%; top: 24%; background: var(--silver); animation-delay: .3s; }
        .brand-particle-copper { width: 14px; height: 14px; left: 20%; bottom: 18%; background: var(--copper); animation-delay: .7s; }
        .brand-particle-gold { width: 10px; height: 10px; right: 22%; bottom: 16%; background: var(--gold-1); animation-delay: 1s; }
        .brand-particle-ruby { width: 11px; height: 11px; top: 28%; left: 9%; background: #d96568; animation-delay: 1.2s; }
        .brand-particle-emerald { width: 11px; height: 11px; right: 10%; top: 32%; background: #6ed5a3; animation-delay: 1.45s; }
        .app-loader {
            position: fixed;
            inset: 0;
            z-index: 100;
            display: grid;
            place-items: center;
            background:
                radial-gradient(circle at center, rgba(199, 155, 83, 0.08), transparent 26%),
                rgba(8, 9, 13, 0.96);
            transition: opacity 500ms ease, visibility 500ms ease;
        }
        .app-loader.is-hidden {
            opacity: 0;
            visibility: hidden;
        }
        .app-loader-mark {
            display: grid;
            gap: 18px;
            place-items: center;
            text-align: center;
        }
        .loader-copy {
            color: var(--muted);
            font-size: 12px;
            letter-spacing: .24em;
            text-transform: uppercase;
        }
        .js-reveal {
            opacity: 0;
            transform: translateY(22px) scale(.985);
            transition: opacity .7s ease, transform .7s ease;
        }
        .js-reveal.in-view {
            opacity: 1;
            transform: translateY(0) scale(1);
        }
        @@keyframes page-enter {
            0% { opacity: 0; transform: translateY(20px); }
            100% { opacity: 1; transform: translateY(0); }
        }
        @@keyframes fade-up {
            0% { opacity: 0; transform: translateY(14px); }
            100% { opacity: 1; transform: translateY(0); }
        }
        @@keyframes sheen-pan {
            from { transform: translateX(-8%); }
            to { transform: translateX(8%); }
        }
        @@keyframes aura-breathe {
            0%, 100% { transform: scale(.96); opacity: .72; }
            50% { transform: scale(1.04); opacity: 1; }
        }
        @@keyframes shadow-breathe {
            0%, 100% { transform: translateZ(-50px) rotateX(84deg) scale(1.12); opacity: .68; }
            50% { transform: translateZ(-50px) rotateX(84deg) scale(1.2); opacity: .9; }
        }
        @@keyframes stage-sway {
            0%, 100% { transform: rotateZ(-2deg) translateY(0); }
            50% { transform: rotateZ(2deg) translateY(-5px); }
        }
        @@keyframes coin-float {
            0%, 100% { transform: translateY(0) scale(1); }
            50% { transform: translateY(-12px) scale(1.01); }
        }
        @@keyframes coin-sheen {
            0% { transform: translate3d(-36%, -22%, 30px) rotate(0deg); opacity: .15; }
            35% { opacity: .65; }
            100% { transform: translate3d(36%, 22%, 30px) rotate(18deg); opacity: .08; }
        }
        @@keyframes coin-rotate {
            from { rotate: y 0deg; }
            to { rotate: y 360deg; }
        }
        @@keyframes orbit-spin {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }
        @@keyframes sparkle {
            from { transform: translateY(0) scale(.88); opacity: .6; filter: drop-shadow(0 0 0 rgba(255,255,255,0)); }
            to { transform: translateY(-8px) scale(1.12); opacity: 1; filter: drop-shadow(0 0 16px currentColor); }
        }
        @@keyframes glow-pulse {
            0%, 100% { transform: scale(.96); opacity: .66; }
            50% { transform: scale(1.02); opacity: 1; }
        }
        @@media (prefers-reduced-motion: reduce) {
            *, *::before, *::after { animation-duration: .01ms !important; animation-iteration-count: 1 !important; transition-duration: .01ms !important; scroll-behavior: auto !important; }
            .js-reveal { opacity: 1; transform: none; }
        }
        @@media (max-width: 920px) {
            .topbar { flex-direction: column; align-items: stretch; position: static; }
            .topbar::before { inset: 0; }
            .shell { width: min(100% - 24px, 1280px); }
            .brand { justify-content: center; }
            .nav { justify-content: center; }
            .hero { padding: 26px; }
            .brand-scene-compact { width: 68px; height: 68px; }
            .brand-scene-hero { width: min(420px, 100%); min-height: 420px; }
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <div id="appLoader" class="app-loader">
        <div class="app-loader-mark">
            @{
                ViewData["BrandMarkMode"] = "compact";
                ViewData["BrandMarkTitle"] = "MGold";
                ViewData["BrandMarkSubtitle"] = "Gold Standard Experience";
            }
            @await Html.PartialAsync("_MGoldBrandMark")
            <div class="loader-copy">Refining the experience</div>
        </div>
    </div>

    <div class="shell">
        <header class="topbar">
            <a asp-controller="Public" asp-action="Index" class="brand">
                @{
                    ViewData["BrandMarkMode"] = "compact";
                    ViewData["BrandMarkTitle"] = "M";
                    ViewData["BrandMarkSubtitle"] = "Compact";
                }
                @await Html.PartialAsync("_MGoldBrandMark")
                <span class="brand-copy">
                    <strong>MGold</strong>
                    <span>Luxury storefront, premium motion, modern digital atelier</span>
                </span>
            </a>
            <nav class="nav">
                <a href="/auth" class="btn btn-secondary">Giris Portali</a>
                <a asp-controller="Public" asp-action="Companies" class="btn btn-secondary">Firmalar</a>
                <a href="/market" class="btn btn-secondary">Canli Market</a>
                @if (!isAuthenticated)
                {
                    <a href="/auth/login" class="btn btn-secondary">Kullanici Girisi</a>
                    <a href="/auth/register" class="btn btn-primary">Kayit Ol</a>
                    <a href="/workspace/login" class="btn btn-secondary">Calisma Alani</a>
                    <a href="/admin/login" class="btn btn-secondary">Platform Girisi</a>
                }
                else if (isSystemAdmin)
                {
                    <a href="/admin" class="btn btn-primary">Admin Paneli</a>
                    <form method="post" action="/account/logout">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="returnUrl" value="@path" />
                        <button type="submit" class="btn btn-secondary">Cikis</button>
                    </form>
                }
                else if (isManager)
                {
                    <a href="/owner" class="btn btn-primary">Firma Paneli</a>
                    <form method="post" action="/account/logout">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="returnUrl" value="@path" />
                        <button type="submit" class="btn btn-secondary">Cikis</button>
                    </form>
                }
                else if (isEmployee)
                {
                    <a href="/employee" class="btn btn-primary">Calisma Alanim</a>
                    <form method="post" action="/account/logout">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="returnUrl" value="@path" />
                        <button type="submit" class="btn btn-secondary">Cikis</button>
                    </form>
                }
                else
                {
                    <a asp-controller="Customer" asp-action="Index" class="btn btn-primary">Musteri Panelim</a>
                    <form method="post" action="/account/logout">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="returnUrl" value="@path" />
                        <button type="submit" class="btn btn-secondary">Cikis</button>
                    </form>
                }
                @await Html.PartialAsync("_ThemeSwitcher")
            </nav>
        </header>
        @if (!(string.Equals(Context.Request.Path, "/auth", StringComparison.OrdinalIgnoreCase) || string.Equals(Context.Request.Path, "/", StringComparison.OrdinalIgnoreCase)))
        {
            <section class="page-header">
                <span class="badge">MGold Experience Layer</span>
                <h1>@title</h1>
                <p>@description</p>
            </section>
        }
        <main class="page-body">
            @RenderBody()
        </main>
    </div>
    @await RenderSectionAsync("Scripts", required: false)
    <script>
        (() => {
            const loader = document.getElementById("appLoader");
            const hideLoader = () => loader?.classList.add("is-hidden");
            window.addEventListener("load", () => setTimeout(hideLoader, 260), { once: true });

            const animatedNodes = document.querySelectorAll(".surface, .hero, .btn, .entry, .metric-card, .module-card, .panel, .order-card, .product-card, .portal-card");
            animatedNodes.forEach((node, index) => {
                node.classList.add("js-reveal");
                node.style.transitionDelay = `${Math.min(index * 35, 220)}ms`;
            });

            const observer = new IntersectionObserver((entries) => {
                entries.forEach((entry) => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add("in-view");
                        observer.unobserve(entry.target);
                    }
                });
            }, { threshold: 0.12, rootMargin: "0px 0px -40px 0px" });

            animatedNodes.forEach((node) => observer.observe(node));

            const interactiveScenes = document.querySelectorAll("[data-coin-scene].brand-scene-hero");
            interactiveScenes.forEach((scene) => {
                let dragging = false;
                let startX = 0;
                let rotation = 0;
                let frame = null;

                const setRotation = (value) => {
                    rotation = value;
                    if (frame) {
                        cancelAnimationFrame(frame);
                    }
                    frame = requestAnimationFrame(() => {
                        scene.style.setProperty("--coin-drag-rotate", `${rotation}deg`);
                    });
                };

                const handleMove = (clientX) => {
                    if (!dragging) return;
                    const delta = clientX - startX;
                    setRotation(delta * 0.22);
                };

                scene.addEventListener("pointerdown", (event) => {
                    event.preventDefault();
                    dragging = true;
                    startX = event.clientX;
                    scene.setPointerCapture?.(event.pointerId);
                });

                scene.addEventListener("pointermove", (event) => handleMove(event.clientX));
                scene.addEventListener("pointerup", (event) => {
                    dragging = false;
                    scene.releasePointerCapture?.(event.pointerId);
                    setRotation(rotation * 0.35);
                });
                scene.addEventListener("pointercancel", (event) => {
                    dragging = false;
                    scene.releasePointerCapture?.(event.pointerId);
                    setRotation(rotation * 0.35);
                });
                scene.addEventListener("pointerleave", () => {
                    dragging = false;
                    setRotation(rotation * 0.35);
                });
            });
        })();
    </script>
</body>
</html>
