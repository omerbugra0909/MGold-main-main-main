@{
    var title = ViewData["Title"]?.ToString() ?? "Müşteri Paneli";
    var description = ViewData["PageDescription"]?.ToString() ?? "Siparişlerinizi ve hesap bilgilerinizi yönetin.";
}
<!doctype html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@title - MGold Customer</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Cinzel:wght@600;700&display=swap" rel="stylesheet">
    @await Html.PartialAsync("_ThemeHead")
    <style>
        :root {
            color-scheme: dark;
            --bg-0: #08090d;
            --bg-1: #10131a;
            --bg-2: #171b22;
            --panel: linear-gradient(180deg, rgba(21, 24, 30, 0.92), rgba(11, 13, 17, 0.95));
            --line: rgba(199, 155, 83, 0.14);
            --ink: #f3ecdf;
            --muted: #9b9184;
            --gold-0: #e3c991;
            --gold-1: #c79b53;
            --gold-2: #8f632b;
            --silver: #aeb6c1;
            --copper: #916348;
            --shadow: 0 30px 80px rgba(0, 0, 0, 0.42);
            --radius-xl: 30px;
            --transition: 280ms cubic-bezier(.2,.8,.2,1);
        }
        * { box-sizing: border-box; }
        body {
            margin: 0;
            min-height: 100vh;
            font-family: "Manrope", sans-serif;
            color: var(--ink);
            background:
                radial-gradient(circle at 16% 8%, rgba(199, 155, 83, 0.12), transparent 22%),
                radial-gradient(circle at 80% 12%, rgba(145, 99, 72, 0.07), transparent 18%),
                linear-gradient(145deg, var(--bg-0) 0%, var(--bg-1) 50%, var(--bg-2) 100%);
            overflow-x: hidden;
        }
        body::before {
            content: "";
            position: fixed;
            inset: 18px;
            border: 1px solid rgba(255, 214, 116, 0.05);
            border-radius: 34px;
            pointer-events: none;
        }
        a { color: inherit; text-decoration: none; }
        .shell { display: grid; grid-template-columns: 286px minmax(0, 1fr); min-height: 100vh; }
        .sidebar {
            position: sticky;
            top: 0;
            height: 100vh;
            padding: 24px 18px;
            background: linear-gradient(180deg, rgba(21, 16, 11, 0.98), rgba(14, 15, 18, 0.98));
            border-right: 1px solid rgba(255,255,255,0.05);
            overflow: auto;
        }
        .brand {
            display: flex;
            align-items: center;
            gap: 16px;
            padding: 18px;
            border-radius: 28px;
            background:
                radial-gradient(circle at top right, rgba(255,214,116,0.08), transparent 28%),
                rgba(255,255,255,0.02);
            border: 1px solid rgba(255, 214, 116, 0.08);
        }
        .brand-copy { display: grid; gap: 4px; }
        .brand-copy strong {
            font-family: "Cinzel", serif;
            font-size: 28px;
            color: var(--gold-0);
            letter-spacing: .06em;
        }
        .brand-copy span { color: var(--muted); font-size: 13px; line-height: 1.55; }
        .nav { display: grid; gap: 10px; margin-top: 22px; }
        .nav a,
        .nav button {
            position: relative;
            overflow: hidden;
            padding: 14px 16px;
            border-radius: 20px;
            background: rgba(255,255,255,0.03);
            border: 1px solid rgba(255,255,255,0.04);
            color: rgba(247, 240, 222, 0.86);
            font: inherit;
            text-align: left;
            cursor: pointer;
            transition: transform var(--transition), border-color var(--transition), background var(--transition), box-shadow var(--transition);
        }
        .nav a::before,
        .nav button::before {
            content: "";
            position: absolute;
            inset: 0;
            background: linear-gradient(120deg, transparent 10%, rgba(255,255,255,0.12) 50%, transparent 90%);
            transform: translateX(-130%);
            transition: transform 680ms ease;
        }
        .nav a:hover::before,
        .nav button:hover::before { transform: translateX(130%); }
        .nav a:hover,
        .nav a.active,
        .nav button:hover {
            transform: translateX(4px);
            border-color: rgba(255, 214, 116, 0.14);
            background: linear-gradient(135deg, rgba(255,214,116,0.08), rgba(255,255,255,0.03));
            box-shadow: 0 18px 36px rgba(0,0,0,0.24);
        }
        .content { padding: 24px; }
        .topbar {
            display: flex;
            justify-content: space-between;
            gap: 18px;
            align-items: center;
            margin-bottom: 20px;
        }
        .topbar-copy h1 {
            margin: 0;
            font-family: "Cinzel", serif;
            font-size: clamp(32px, 4vw, 44px);
            letter-spacing: .04em;
        }
        .topbar-copy p { margin: 10px 0 0; color: var(--muted); max-width: 820px; }
        .pill {
            padding: 14px 16px;
            border-radius: 20px;
            background: rgba(255,255,255,0.03);
            border: 1px solid rgba(255, 214, 116, 0.08);
            box-shadow: var(--shadow);
            color: var(--muted);
        }
        .surface {
            position: relative;
            overflow: hidden;
            background: var(--panel);
            border: 1px solid rgba(255, 214, 116, 0.08);
            border-radius: var(--radius-xl);
            box-shadow: var(--shadow);
            backdrop-filter: blur(18px);
            transition: transform var(--transition), border-color var(--transition), box-shadow var(--transition);
        }
        .surface::before {
            content: "";
            position: absolute;
            inset: 1px;
            border-radius: inherit;
            background:
                linear-gradient(180deg, rgba(255,255,255,0.05), transparent 28%),
                radial-gradient(circle at top right, rgba(255,214,116,0.08), transparent 22%);
            pointer-events: none;
        }
        .surface:hover {
            transform: translateY(-4px);
            border-color: rgba(255, 214, 116, 0.16);
            box-shadow: 0 34px 90px rgba(0,0,0,0.5);
        }
        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-height: 46px;
            padding: 11px 17px;
            border-radius: 999px;
            border: 1px solid transparent;
            font: inherit;
            font-weight: 700;
            cursor: pointer;
            transition: transform var(--transition), box-shadow var(--transition), border-color var(--transition), background var(--transition);
        }
        .btn:hover { transform: translateY(-2px); }
        .btn-primary {
            color: #140e08;
            background: linear-gradient(135deg, rgba(227, 201, 145, 0.92), rgba(143, 99, 43, 0.82));
            box-shadow: 0 18px 42px rgba(79, 53, 25, 0.24);
        }
        .btn-secondary,
        .btn {
            color: var(--gold-0);
            background: rgba(255,255,255,0.04);
            border-color: rgba(255,255,255,0.07);
        }
        .badge {
            display: inline-flex;
            align-items: center;
            padding: 7px 12px;
            border-radius: 999px;
            background: rgba(255, 214, 116, 0.08);
            border: 1px solid rgba(255, 214, 116, 0.12);
            color: var(--gold-1);
            font-size: 11px;
            font-weight: 800;
            letter-spacing: .12em;
            text-transform: uppercase;
        }
        .text-muted { color: var(--muted); }
        .empty-state {
            padding: 18px;
            border-radius: 18px;
            border: 1px dashed rgba(255, 214, 116, 0.12);
            background: rgba(255,255,255,0.03);
            color: var(--muted);
        }
        input, select, textarea {
            width: 100%;
            border: 1px solid rgba(255, 214, 116, 0.12);
            border-radius: 18px;
            padding: 12px 14px;
            background: rgba(255,255,255,0.04);
            color: var(--ink);
            font: inherit;
            transition: border-color var(--transition), box-shadow var(--transition), transform var(--transition);
        }
        input:focus, select:focus, textarea:focus {
            outline: none;
            border-color: rgba(255, 214, 116, 0.28);
            box-shadow: 0 0 0 4px rgba(241, 197, 111, 0.08);
            transform: translateY(-1px);
        }
        .brand-scene { --coin-tilt-x: -16deg; --coin-tilt-y: 22deg; --coin-drag-rotate: 0deg; position: relative; perspective: 1800px; display: grid; place-items: center; pointer-events: none; user-select: none; }
        .brand-scene-compact { width: 82px; height: 82px; flex: 0 0 auto; }
        .brand-scene-core { position: relative; width: 100%; aspect-ratio: 1; display: grid; place-items: center; transform-style: preserve-3d; filter: drop-shadow(0 32px 56px rgba(0,0,0,0.52)); }
        .brand-coin-aura { position: absolute; inset: 10%; border-radius: 50%; background: radial-gradient(circle, rgba(199,155,83,0.14), rgba(199,155,83,0.04) 36%, transparent 68%), radial-gradient(circle at 32% 28%, rgba(255,255,255,0.12), transparent 18%); filter: blur(22px); animation: aura-breathe 6s ease-in-out infinite; }
        .brand-coin-stage { position: relative; width: 78%; aspect-ratio: 1; display: grid; place-items: center; transform-style: preserve-3d; animation: stage-sway 9s ease-in-out infinite; }
        .brand-coin-motion { position: relative; width: 86%; aspect-ratio: 1; display: grid; place-items: center; transform-style: preserve-3d; animation: coin-float 7.6s ease-in-out infinite; }
        .brand-coin-shadow { position: absolute; inset: 24% 12% 12%; border-radius: 50%; background: radial-gradient(circle, rgba(0,0,0,0.58), rgba(0,0,0,0.08) 62%, transparent 78%); filter: blur(26px); transform: translateZ(-50px) rotateX(84deg) scale(1.18); animation: shadow-breathe 6s ease-in-out infinite; }
        .brand-coin { position: relative; width: 100%; aspect-ratio: 1; transform-style: preserve-3d; transform: rotateX(var(--coin-tilt-x)) rotateY(calc(var(--coin-tilt-y) + var(--coin-drag-rotate))) translateZ(0); transition: transform 180ms ease-out; will-change: transform; }
        .brand-coin-side { position: absolute; inset: 7%; border-radius: 50%; background: repeating-conic-gradient(from 0deg, rgba(230,205,151,0.82) 0deg 8deg, rgba(126,86,36,0.86) 8deg 16deg); transform: translateZ(-24px); box-shadow: inset 0 0 0 8px rgba(91,59,24,0.4), 0 10px 32px rgba(0,0,0,0.22); }
        .brand-coin-face { position: absolute; inset: 0; border-radius: 50%; display: grid; place-items: center; backface-visibility: hidden; overflow: hidden; }
        .brand-coin-front, .brand-coin-back { background: radial-gradient(circle at 26% 18%, rgba(245,236,212,0.95), rgba(225,198,140,0.9) 16%, rgba(186,139,72,0.88) 50%, rgba(116,78,34,0.94) 74%, rgba(45,31,13,0.98) 100%); box-shadow: inset 0 14px 24px rgba(255,255,255,0.16), inset 0 -18px 28px rgba(74,48,21,0.42), 0 0 44px rgba(199,155,83,0.12); }
        .brand-coin-front { transform: translateZ(24px); }
        .brand-coin-back { transform: rotateY(180deg) translateZ(24px); }
        .brand-coin-face-sheen { position: absolute; inset: -10%; background: linear-gradient(120deg, transparent 24%, rgba(255,255,255,0.24) 40%, transparent 56%), linear-gradient(200deg, transparent 16%, rgba(227,201,145,0.08) 36%, transparent 62%); mix-blend-mode: screen; animation: coin-sheen 5.2s linear infinite; }
        .brand-coin-rim { position: absolute; border-radius: 50%; border-style: solid; }
        .brand-coin-rim-outer { inset: 4.5%; border-width: 2px; border-color: rgba(243,228,193,0.46); box-shadow: inset 0 0 0 10px rgba(106,71,31,0.16), 0 0 16px rgba(199,155,83,0.08); }
        .brand-coin-rim-inner { inset: 13%; border-width: 1px; border-color: rgba(243,230,204,0.24); box-shadow: inset 0 0 0 5px rgba(227,201,145,0.04); }
        .brand-coin-center { position: relative; width: 58%; aspect-ratio: 1; border-radius: 50%; display: grid; place-items: center; align-content: center; gap: 4px; background: radial-gradient(circle at 30% 24%, rgba(232,214,177,0.18), rgba(255,255,255,0.03) 28%, transparent 62%), radial-gradient(circle, rgba(78,53,26,0.18), transparent 70%); box-shadow: inset 0 0 0 1px rgba(255,255,255,0.1), inset 0 10px 16px rgba(255,255,255,0.04), inset 0 -12px 16px rgba(54,35,15,0.14); transform: translateZ(10px); }
        .brand-coin-engrave { font-family: "Cinzel", serif; font-size: 18px; letter-spacing: .11em; color: rgba(67,43,18,0.9); text-shadow: 0 1px 0 rgba(255,255,255,0.22), 0 -1px 0 rgba(78,51,22,0.28), 0 8px 16px rgba(76,50,22,0.12); transform: translateZ(12px); }
        .brand-coin-etch { position: absolute; inset: 20%; border-radius: 50%; border: 1px solid rgba(227,201,145,0.1); transform: translateZ(6px); }
        .brand-coin-etch-b { inset: 24%; border-style: dashed; opacity: .46; }
        .brand-coin-glyph { position: absolute; width: 54%; height: 2px; background: linear-gradient(90deg, transparent, rgba(233,220,190,0.56), transparent); opacity: .58; }
        .brand-coin-glyph-top { top: 24%; }
        .brand-coin-glyph-bottom { bottom: 24%; }
        .brand-coin-insignia { width: 40%; height: 40%; border-radius: 50%; background: radial-gradient(circle at 32% 32%, rgba(255,255,255,0.2), transparent 18%), radial-gradient(circle, rgba(104,57,12,0.78), rgba(66,35,7,0.18)); box-shadow: inset 0 0 0 1px rgba(255,255,255,0.24), inset 0 12px 16px rgba(255,255,255,0.1); transform: translateZ(8px); }
        .brand-coin-back-grid { position: absolute; inset: 26%; border-radius: 50%; background: repeating-linear-gradient(0deg, transparent 0 12%, rgba(255,255,255,0.04) 12% 14%, transparent 14% 26%), repeating-linear-gradient(90deg, transparent 0 12%, rgba(255,255,255,0.04) 12% 14%, transparent 14% 26%); opacity: .55; }
        .brand-glow-ring { position: absolute; aspect-ratio: 1; border-radius: 50%; animation: glow-pulse 4.6s ease-in-out infinite; }
        .brand-glow-ring-outer { width: 88%; border: 1px solid rgba(199,155,83,0.14); box-shadow: 0 0 36px rgba(199,155,83,0.12), inset 0 0 26px rgba(199,155,83,0.03); }
        .brand-glow-ring-inner { width: 64%; border: 1px solid rgba(233,220,190,0.09); animation-delay: -.8s; }
        .brand-orbit { position: absolute; border-radius: 50%; border: 1px dashed rgba(255,255,255,0.08); animation: orbit-spin 12s linear infinite; pointer-events: none; }
        .brand-orbit::before, .brand-orbit::after { content: ""; position: absolute; border-radius: 50%; filter: drop-shadow(0 0 14px currentColor); }
        .brand-orbit-silver { inset: 4%; color: rgba(174,182,193,0.78); }
        .brand-orbit-silver::before { width: 12px; height: 12px; top: -5px; left: 40%; background: currentColor; }
        .brand-orbit-silver::after { width: 8px; height: 8px; bottom: 14%; right: 10%; background: currentColor; }
        .brand-orbit-copper { inset: 14%; animation-duration: 18s; animation-direction: reverse; color: rgba(145,99,72,0.7); }
        .brand-orbit-copper::before { width: 14px; height: 14px; top: 19%; right: -4px; background: currentColor; }
        .brand-orbit-copper::after { width: 8px; height: 8px; bottom: -2px; left: 28%; background: currentColor; }
        .brand-orbit-gem { inset: -3%; animation-duration: 26s; color: rgba(143,197,218,0.76); }
        .brand-orbit-gem::before { width: 16px; height: 16px; top: 32%; left: -2px; background: radial-gradient(circle at 30% 30%, #ffffff, currentColor 45%, rgba(143,197,218,0.15) 100%); clip-path: polygon(50% 0%, 100% 35%, 78% 100%, 22% 100%, 0% 35%); }
        .brand-orbit-gem::after { width: 9px; height: 9px; top: 7%; right: 18%; background: currentColor; }
        .brand-particle { position: absolute; border-radius: 50%; opacity: .92; animation: sparkle 3.4s ease-in-out infinite alternate; pointer-events: none; }
        .brand-particle-diamond { width: 18px; height: 18px; top: 18%; right: 16%; background: radial-gradient(circle at 30% 30%, #ffffff, rgba(143,197,218,0.82) 45%, rgba(143,197,218,0.14) 100%); clip-path: polygon(50% 0%, 100% 36%, 78% 100%, 22% 100%, 0% 36%); }
        .brand-particle-silver { width: 12px; height: 12px; left: 14%; top: 24%; background: var(--silver); animation-delay: .3s; }
        .brand-particle-copper { width: 14px; height: 14px; left: 20%; bottom: 18%; background: var(--copper); animation-delay: .7s; }
        .brand-particle-gold { width: 10px; height: 10px; right: 22%; bottom: 16%; background: var(--gold-1); animation-delay: 1s; }
        .brand-particle-ruby { width: 11px; height: 11px; top: 28%; left: 9%; background: #d96568; animation-delay: 1.2s; }
        .brand-particle-emerald { width: 11px; height: 11px; right: 10%; top: 32%; background: #6ed5a3; animation-delay: 1.45s; }
        .app-loader {
            position: fixed;
            inset: 0;
            z-index: 100;
            display: grid;
            place-items: center;
            background: radial-gradient(circle at center, rgba(199, 155, 83, 0.07), transparent 28%), rgba(8, 9, 13, 0.97);
            transition: opacity 500ms ease, visibility 500ms ease;
        }
        .app-loader.is-hidden { opacity: 0; visibility: hidden; }
        .app-loader-mark { display: grid; gap: 16px; place-items: center; text-align: center; }
        .loader-copy { color: var(--muted); font-size: 12px; letter-spacing: .22em; text-transform: uppercase; }
        .js-reveal {
            opacity: 0;
            transform: translateY(22px) scale(.985);
            transition: opacity .7s ease, transform .7s ease;
        }
        .js-reveal.in-view { opacity: 1; transform: translateY(0) scale(1); }
        @@keyframes aura-breathe {
            0%, 100% { transform: scale(.96); opacity: .72; }
            50% { transform: scale(1.04); opacity: 1; }
        }
        @@keyframes shadow-breathe {
            0%, 100% { transform: translateZ(-50px) rotateX(84deg) scale(1.12); opacity: .68; }
            50% { transform: translateZ(-50px) rotateX(84deg) scale(1.2); opacity: .9; }
        }
        @@keyframes stage-sway {
            0%, 100% { transform: rotateZ(-2deg) translateY(0); }
            50% { transform: rotateZ(2deg) translateY(-5px); }
        }
        @@keyframes coin-float {
            0%, 100% { transform: translateY(0) scale(1); }
            50% { transform: translateY(-11px) scale(1.01); }
        }
        @@keyframes coin-sheen {
            0% { transform: translate3d(-36%, -22%, 30px) rotate(0deg); opacity: .15; }
            35% { opacity: .65; }
            100% { transform: translate3d(36%, 22%, 30px) rotate(18deg); opacity: .08; }
        }
        @@keyframes coin-rotate {
            from { rotate: y 0deg; }
            to { rotate: y 360deg; }
        }
        @@keyframes orbit-spin {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }
        @@keyframes sparkle {
            from { transform: translateY(0) scale(.88); opacity: .6; filter: drop-shadow(0 0 0 rgba(255,255,255,0)); }
            to { transform: translateY(-8px) scale(1.12); opacity: 1; filter: drop-shadow(0 0 16px currentColor); }
        }
        @@keyframes glow-pulse {
            0%, 100% { transform: scale(.96); opacity: .66; }
            50% { transform: scale(1.02); opacity: 1; }
        }
        @@media (prefers-reduced-motion: reduce) {
            *, *::before, *::after { animation-duration: .01ms !important; animation-iteration-count: 1 !important; transition-duration: .01ms !important; }
            .js-reveal { opacity: 1; transform: none; }
        }
        @@media (max-width: 1040px) {
            .shell { grid-template-columns: 1fr; }
            .sidebar { position: static; height: auto; }
            .topbar { flex-direction: column; align-items: stretch; }
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <div id="appLoader" class="app-loader">
        <div class="app-loader-mark">
            @{
                ViewData["BrandMarkMode"] = "compact";
                ViewData["BrandMarkTitle"] = "MGold";
            }
            @await Html.PartialAsync("_MGoldBrandMark")
            <div class="loader-copy">Müşteri paneli hazırlanıyor</div>
        </div>
    </div>

    @{
        var controller = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
        string navClass(string c, string? a = null)
        {
            var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
            return string.Equals(controller, c, StringComparison.OrdinalIgnoreCase) &&
                   (a is null || string.Equals(currentAction, a, StringComparison.OrdinalIgnoreCase))
                ? "active"
                : string.Empty;
        }
    }
    <div class="shell">
        <aside class="sidebar">
            <div class="brand">
                @{
                    ViewData["BrandMarkMode"] = "compact";
                    ViewData["BrandMarkTitle"] = "M";
                }
                @await Html.PartialAsync("_MGoldBrandMark")
                <span class="brand-copy">
                    <strong>MGold Müşteri</strong>
                    <span>Siparişler, favoriler ve hesap işlemleri için kişisel panel.</span>
                </span>
            </div>
            <nav class="nav">
                <a class="@navClass("Customer","Index")" asp-controller="Customer" asp-action="Index">Panelim</a>
                <a asp-controller="Public" asp-action="Companies">Firma Keşfet</a>
                <a class="@navClass("Customer","Orders")" asp-controller="Customer" asp-action="Orders">Siparişlerim</a>
                <a class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Market" ? "active" : "")" asp-controller="Market" asp-action="Customer">Canlı Piyasalar</a>
                <a class="@navClass("Customer","Favorites")" asp-controller="Customer" asp-action="Favorites">Favoriler</a>
                <a class="@navClass("Customer","Profile")" asp-controller="Customer" asp-action="Profile">Hesabım</a>
                <a class="@navClass("Customer","Contact")" asp-controller="Customer" asp-action="Contact">İletişim</a>
                <a asp-controller="Public" asp-action="Companies">Mağaza</a>
                <form method="post" action="/account/logout">
                    @Html.AntiForgeryToken()
                    <button type="submit">Çıkış Yap</button>
                </form>
            </nav>
        </aside>
        <main class="content">
            <header class="topbar">
                <div class="topbar-copy">
                    <span class="badge">Müşteri Paneli</span>
                    <h1>@title</h1>
                    <p>@description</p>
                </div>
                <div class="topbar-actions">
                    @await Html.PartialAsync("_ThemeSwitcher")
                    <div class="pill">Hesap işlemleriniz kontrollü ve güvenli bir panelde tutulur.</div>
                </div>
            </header>
            @RenderBody()
        </main>
    </div>
    @await RenderSectionAsync("Scripts", required: false)
    <script>
        (() => {
            const loader = document.getElementById("appLoader");
            window.addEventListener("load", () => setTimeout(() => loader?.classList.add("is-hidden"), 240), { once: true });
            const animatedNodes = document.querySelectorAll(".surface, .btn, .entry, .metric, .module-card, .panel, .order-card, .favorite-card, .product-card, .message-card");
            animatedNodes.forEach((node, index) => {
                node.classList.add("js-reveal");
                node.style.transitionDelay = `${Math.min(index * 30, 210)}ms`;
            });
            const observer = new IntersectionObserver((entries) => {
                entries.forEach((entry) => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add("in-view");
                        observer.unobserve(entry.target);
                    }
                });
            }, { threshold: 0.12, rootMargin: "0px 0px -48px 0px" });
            animatedNodes.forEach((node) => observer.observe(node));
        })();
    </script>
</body>
</html>
