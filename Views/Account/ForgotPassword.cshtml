@model MGold.Controllers.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Sifremi Unuttum";
    ViewData["PageDescription"] = "E-posta veya SMS dogrulamasi ile sifrenizi guvenli sekilde yenileyin.";
}

@section Styles {
    <style>
        .reset-wrap { width:min(620px, 100%); margin:0 auto; padding:28px; display:grid; gap:16px; }
        .reset-wrap h2 { margin:0; font-family:"Space Grotesk", sans-serif; font-size:32px; }
        .reset-form { display:grid; gap:14px; }
        .channel-grid { display:grid; grid-template-columns:1fr 1fr; gap:10px; }
        .channel-grid label { padding:14px; border-radius:18px; border:1px solid rgba(98,67,25,.12); background:rgba(255,255,255,.55); cursor:pointer; }
        .hint { padding:14px 16px; border-radius:18px; background:rgba(111,71,16,.08); color:var(--muted); }
        @@media (max-width:700px) { .channel-grid { grid-template-columns:1fr; } }
    </style>
}

<section class="surface reset-wrap">
    <span class="badge">Secure Recovery</span>
    <h2>Sifremi Unuttum</h2>
    <p class="text-muted">Kayitli e-posta adresinizi, telefon numaranizi veya kullanici adinizi girin. Dogrulama kodu/baglantisi yalnizca aktif ve dogrulanmis hesaba gonderilir.</p>

    <form method="post" class="reset-form">
        @Html.AntiForgeryToken()
        @Html.ValidationSummary(false)
        <label>
            <span>E-posta / telefon / kullanici adi</span>
            <input asp-for="Identifier" autocomplete="username" />
        </label>
        <div class="channel-grid">
            <label>
                <input type="radio" asp-for="Channel" value="email" checked="@(Model.Channel == "email")" />
                <strong>E-posta</strong>
                <div class="text-muted">Giris baglantisi ve token gonderilir.</div>
            </label>
            <label>
                <input type="radio" asp-for="Channel" value="sms" checked="@(Model.Channel == "sms")" />
                <strong>SMS</strong>
                <div class="text-muted">6 haneli kod telefonunuza gider.</div>
            </label>
        </div>
        <button type="submit" class="btn btn-primary">Dogrulama gonder</button>
    </form>

    <div class="hint">
        Guvenlik icin kodlar surelidir, fazla hatali denemede gecersiz olur ve yeni kod icin kisa bekleme uygulanir.
    </div>
</section>
