            color: #fff4d6;
            box-shadow: inset 0 0 0 1px rgba(255, 223, 166, 0.16);
        }
        body.admin-theme .sidebar-link.active {
            background: linear-gradient(135deg, rgba(124, 167, 255, 0.24), rgba(255, 255, 255, 0.04));
            color: #e8f1ff;
            box-shadow: inset 0 0 0 1px rgba(191, 210, 255, 0.12);
        }
        .nav-icon {
