@using Microsoft.AspNetCore.Authentication.Cookies
@using MGold.Domain.Constants
@{
    var controller = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
    var action = ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty;
    var pageTitle = ViewData["Title"]?.ToString() ?? "MGold";
    var isAdminArea = string.Equals(controller, "Admin", StringComparison.OrdinalIgnoreCase);
    var isAuthenticated = User.Identity?.IsAuthenticated == true;
    var isAdmin = User.IsInRole(RoleConstants.Admin);
    var returnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
    var authErrors = (TempData["AuthErrors"]?.ToString() ?? string.Empty)
        .Split("||", StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
    var authInfo = TempData["AuthInfo"]?.ToString();
    var openAuthModal = string.Equals(TempData["OpenAuthModal"]?.ToString(), "true", StringComparison.OrdinalIgnoreCase);
    var authTab = TempData["AuthTab"]?.ToString() ?? "login";

    string NavClass(string targetController, string? targetAction = null)
    {
        var matchesController = string.Equals(controller, targetController, StringComparison.OrdinalIgnoreCase);
        var matchesAction = targetAction is null || string.Equals(action, targetAction, StringComparison.OrdinalIgnoreCase);
        return matchesController && matchesAction ? "sidebar-link active" : "sidebar-link";
    }
}
<!doctype html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@pageTitle - MGold</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;700&display=swap" rel="stylesheet">
    @await Html.PartialAsync("_ThemeHead")
    <style>
        :root {
            --bg: #f4efe7;
            --panel: rgba(255, 251, 245, 0.86);
            --panel-strong: rgba(255, 248, 236, 0.98);
            --line: rgba(98, 67, 25, 0.12);
            --ink: #22180f;
            --muted: #7f6f5d;
            --brand: #996515;
            --brand-strong: #6f4710;
            --accent: #dcb35c;
            --danger: #b74747;
            --success: #2d7a57;
            --shadow: 0 26px 60px rgba(58, 40, 18, 0.12);
        }
        * { box-sizing: border-box; }
        html { scroll-behavior: smooth; }
        body {
            margin: 0;
            min-height: 100vh;
            font-family: "Outfit", sans-serif;
            color: var(--ink);
            background:
                radial-gradient(circle at top left, rgba(242, 205, 120, 0.28), transparent 24%),
                radial-gradient(circle at 85% 10%, rgba(160, 208, 190, 0.18), transparent 18%),
                linear-gradient(135deg, #f6f2ec 0%, #efe7dc 50%, #f8f4ee 100%);
        }
        body.admin-theme {
            --bg: #10141d;
            --panel: rgba(20, 27, 40, 0.9);
            --panel-strong: rgba(16, 22, 34, 0.98);
            --line: rgba(145, 167, 210, 0.12);
            --ink: #eef3ff;
            --muted: #99a6c1;
            --brand: #7ca7ff;
            --brand-strong: #bfd2ff;
            --accent: #5f84ff;
            --danger: #ff7575;
            --success: #6ed6a8;
            --shadow: 0 26px 70px rgba(0, 0, 0, 0.32);
            background:
                radial-gradient(circle at top left, rgba(95, 132, 255, 0.22), transparent 24%),
                radial-gradient(circle at 85% 10%, rgba(87, 206, 170, 0.12), transparent 18%),
                linear-gradient(135deg, #0b0f17 0%, #151b27 55%, #0f1520 100%);
        }
        a { color: inherit; }
        .dashboard-shell {
            display: grid;
            grid-template-columns: 280px minmax(0, 1fr);
            min-height: 100vh;
        }
        .sidebar {
            position: sticky;
            top: 0;
            height: 100vh;
            padding: 24px 18px;
            border-right: 1px solid rgba(255, 255, 255, 0.06);
            background: linear-gradient(180deg, rgba(47, 31, 8, 0.96) 0%, rgba(77, 51, 17, 0.96) 100%);
            color: #f7efe2;
        }
        body.admin-theme .sidebar {
            background: linear-gradient(180deg, rgba(9, 13, 20, 0.98) 0%, rgba(16, 24, 38, 0.98) 100%);
            color: #ecf3ff;
        }
        .brand-block {
            padding: 18px;
            border-radius: 24px;
            background: linear-gradient(160deg, rgba(255, 221, 150, 0.24), rgba(255, 255, 255, 0.06));
            border: 1px solid rgba(255, 233, 191, 0.12);
            box-shadow: inset 0 1px 0 rgba(255,255,255,0.06);
        }
        body.admin-theme .brand-block {
            background: linear-gradient(160deg, rgba(124, 167, 255, 0.16), rgba(255, 255, 255, 0.02));
            border-color: rgba(191, 210, 255, 0.08);
        }
        .brand-kicker {
