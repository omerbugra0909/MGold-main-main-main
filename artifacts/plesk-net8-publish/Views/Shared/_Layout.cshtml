        }
        .brand-title {
            margin: 10px 0 6px;
            font-family: "Space Grotesk", sans-serif;
            font-size: 30px;
            font-weight: 700;
        }
        .brand-copy {
            margin: 0;
            color: rgba(247, 239, 226, 0.74);
            line-height: 1.5;
            font-size: 14px;
        }
        body.admin-theme .brand-copy {
            color: rgba(228, 237, 255, 0.72);
        }
        .sidebar-section {
            margin-top: 22px;
        }
        .sidebar-label {
            margin: 0 0 10px;
            padding: 0 10px;
            font-size: 11px;
            letter-spacing: .18em;
            text-transform: uppercase;
            color: rgba(255, 241, 215, 0.52);
        }
        body.admin-theme .sidebar-label {
