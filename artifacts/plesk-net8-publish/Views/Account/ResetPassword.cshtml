@model MGold.Controllers.ResetPasswordViewModel
@{
    ViewData["Title"] = "Şifre Yenile";
    ViewData["PageDescription"] = "Doğrulama kodu veya güvenli token ile yeni şifrenizi belirleyin.";
}

@section Styles {
    <style>
        .reset-wrap { width:min(620px, 100%); margin:0 auto; padding:28px; display:grid; gap:16px; }
        .reset-wrap h2 { margin:0; font-family:"Space Grotesk", sans-serif; font-size:32px; }
        .reset-form { display:grid; gap:14px; }
        .notice { padding:14px 16px; border-radius:18px; background:rgba(111,71,16,.08); color:var(--muted); }
        .notice.ok { background:rgba(45,122,87,.12); color:#2d7a57; }
        .notice.err { background:rgba(183,71,71,.12); color:#9b2f2f; }
    </style>
}

<section class="surface reset-wrap">
    <span class="badge">Password Reset</span>
    <h2>Yeni şifrenizi belirleyin</h2>
    <p class="text-muted">E-postadaki bağlantıdan geldiyseniz token otomatik doludur. SMS kullaniyorsaniz telefonunuza gelen 6 haneli kodu yazin.</p>

    @if (TempData["Success"] is string ok)
    {
        <div class="notice ok">@ok</div>
    }
    @if (TempData["Error"] is string error)
    {
        <div class="notice err">@error</div>
    }

    <form method="post" class="reset-form">
        @Html.AntiForgeryToken()
        @Html.ValidationSummary(false)
        <input type="hidden" asp-for="UserId" />
        <input type="hidden" asp-for="Channel" />
        <label>
            <span>E-posta / telefon / kullanıcı adi</span>
            <input asp-for="Identifier" placeholder="SMS ile yeniliyorsaniz doldürün" />
        </label>
        <label>
            <span>Kod veya token</span>
            <input asp-for="TokenOrCode" autocomplete="one-time-code" />
        </label>
        <label>
            <span>Yeni şifre</span>
            <input asp-for="NewPassword" type="password" autocomplete="new-password" />
        </label>
        <button type="submit" class="btn btn-primary">Şifremi yenile</button>
    </form>

    <div class="notice">
        Kodunuzun suresi dolduysa <a href="/auth/forgot-password"><strong>yeni doğrulama isteyin</strong></a>.
    </div>
</section>
