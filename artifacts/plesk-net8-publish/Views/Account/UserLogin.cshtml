@model MGold.Controllers.UserLoginViewModel
@{
    ViewData["Title"] = "Kullanıcı Girişi";
    ViewData["PageDescription"] = "Müşteri hesabınizla giriş yapın ve sadece size ait işlemleri yönetin.";
    var returnUrl = ViewData["ReturnUrl"]?.ToString();
}

@section Styles {
    <style>
        .auth-wrap {
            width: min(560px, 100%);
            margin: 0 auto;
            padding: 28px;
        }
        .auth-wrap h2 {
            margin: 0 0 10px;
            font-family: "Space Grotesk", sans-serif;
            font-size: 32px;
        }
        .auth-form { display: grid; gap: 14px; margin-top: 16px; }
        .auth-note {
            padding: 14px 16px;
            border-radius: 18px;
            background: rgba(111, 71, 16, 0.08);
            color: var(--muted);
        }
    </style>
}

<section class="surface auth-wrap">
    <span class="badge">Customer Login</span>
    <h2>Kullanıcı Girişi</h2>
    <p class="text-muted">Bu ekran yalnızca normal müşteri hesapları içindir. Admin hesapları ayrıca korunur.</p>

    <form method="post" class="auth-form">
        @Html.AntiForgeryToken()
        <input type="hidden" name="returnUrl" value="@returnUrl" />
        @Html.ValidationSummary(false)
        <label>
            <span>E-posta veya Kullanıcı Adi</span>
            <input asp-for="EmailOrUsername" />
        </label>
        <label>
            <span>Şifre</span>
            <input asp-for="Password" type="password" />
        </label>
        <button type="submit" class="btn btn-primary">Giriş Yap</button>
    </form>

    <div class="auth-note" style="margin-top:16px;">
        Hesabiniz yoksa <a href="/auth/register"><strong>yeni müşteri kaydı</strong></a> oluşturabilirsiniz.
        Şifrenizi unuttuysaniz <a href="/auth/forgot-password"><strong>güvenli şifre yenileme</strong></a> akışını kullanin.
    </div>
</section>
