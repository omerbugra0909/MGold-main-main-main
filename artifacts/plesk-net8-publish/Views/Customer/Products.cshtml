@model MGold.Controllers.CustomerProductsPageViewModel
@{
    ViewData["Title"] = $"{Model.CompanyName} Ürünleri";
    ViewData["PageDescription"] = "Seçili firmaya ait ürünleri müşteri akışında inceleyin.";
    var returnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
}

@section Styles {
    <style>
        .stack { display: grid; gap: 18px; }
        .filter-card, .grid-card { padding: 22px; }
        .filters {
            display: grid;
            grid-template-columns: 1.5fr .8fr auto;
            gap: 12px;
        }
        .product-grid {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 16px;
        }
        .product-card { padding: 20px; }
        .product-card h3 {
            margin: 0;
            font-family: "Space Grotesk", sans-serif;
            font-size: 22px;
        }
        .actions { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 16px; }
        .order-form {
            display: grid;
            grid-template-columns: 86px minmax(150px, 1fr);
            gap: 10px;
            width: 100%;
            margin-top: 14px;
        }
        .order-form textarea,
        .order-form button { grid-column: 1 / -1; }
        @@media (max-width: 1080px) {
            .product-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
        }
        @@media (max-width: 820px) {
            .filters, .product-grid { grid-template-columns: 1fr; }
        }
    </style>
}

<div class="stack">
    @if (TempData["Success"] is string ok && !string.IsNullOrWhiteSpace(ok))
    {
        <div class="message message-success">@ok</div>
    }
    @if (TempData["Error"] is string error && !string.IsNullOrWhiteSpace(error))
    {
        <div class="message message-error">@error</div>
    }

    <section class="surface filter-card">
        <div style="margin-bottom:14px;">
            <span class="badge">Seçili Firma</span>
            <h2 style="margin:8px 0 0;">@Model.CompanyName</h2>
        </div>
        <form method="get" class="filters">
            <input type="hidden" name="companyId" value="@Model.CompanyId" />
            <input type="text" name="search" value="@Model.Search" placeholder="Ürün ara" />
            <select name="type" asp-items="Html.GetEnumSelectList<MGold.Domain.Enums.ProductType>()">
                <option value="">Tüm kategoriler</option>
            </select>
            <button type="submit" class="btn btn-primary">Filtrele</button>
        </form>
    </section>

    <section class="surface grid-card">
        @if (!Model.Products.Any())
        {
            <div class="empty-state">Filtreye uygun ürün bulunamadı.</div>
        }
        else
        {
            <div class="product-grid">
                @foreach (var product in Model.Products)
                {
                    <article class="surface product-card">
                        <div class="cluster">
                            <span class="badge">@product.Type</span>
                            @if (product.IsFavorite)
                            {
                                <span class="badge">Favori</span>
                            }
                        </div>
                        <h3 style="margin-top:14px;">@product.Name</h3>
                        <div class="text-muted" style="margin-top:8px;">@product.Weight.ToString("N2") gr • Stok: @product.StockQuantity</div>
                        <div style="margin-top:14px; font-family:'Space Grotesk', sans-serif; font-size:28px; color:var(--brand-strong);">@product.SalePrice.ToString("N2") TL</div>
                        <div class="actions">
                            <a href="/companies/@Model.CompanyId" class="btn btn-secondary">Firma Profilinde Aç</a>
                            <form method="post" asp-action="ToggleFavorite">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="productId" value="@product.Id" />
                                <input type="hidden" name="returnUrl" value="@returnUrl" />
                                <button type="submit" class="btn btn-primary">@(product.IsFavorite ? "Favoriden Cikar" : "Favoriye Ekle")</button>
                            </form>
                        </div>
                        <form method="post" asp-controller="Public" asp-action="PlaceOrder" class="order-form">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="productId" value="@product.Id" />
                            <input type="hidden" name="returnUrl" value="@returnUrl" />
                            <input name="quantity" type="number" min="1" max="@product.StockQuantity" value="1" />
                            <select name="preferredPaymentMethod">
                                @foreach (var method in Enum.GetValues<MGold.Domain.Enums.PaymentMethod>())
                                {
                                    <option value="@method">@method</option>
                                }
                            </select>
                            <textarea name="notes" rows="2" placeholder="Sipariş notu"></textarea>
                            <button type="submit" class="btn btn-primary" @(product.StockQuantity <= 0 ? "disabled" : null)>Sipariş Ver</button>
                        </form>
                    </article>
                }
            </div>
        }
    </section>
</div>
